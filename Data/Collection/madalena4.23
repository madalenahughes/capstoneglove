#include <Arduino.h>
#include <HardwareSerial.h>
#include <math.h>

// =========================
// Sensor pins
// =========================
const int FIST_PIN      = 34;
const int PINCH_PIN     = 39;
const int EXTENSION_PIN = 36;

const int delayTime = 50;   // ms between reads

// =========================
// UART2 to Raspberry Pi
// =========================
HardwareSerial mySerial(2);

// =========================
// Moving average smoothing
// =========================
const int AVG_N = 20;

int bufF[AVG_N] = {0};
int bufP[AVG_N] = {0};
int bufE[AVG_N] = {0};

int idxF = 0, idxP = 0, idxE = 0;
long sumF = 0, sumP = 0, sumE = 0;

// =========================
// Gesture averaging buffer
// =========================
const int GESTURE_AVG_N = 10;

enum Gesture {
  REST = 0,
  FIST,
  PINCH,
  PEACE,
  POINT,
  THUMB,
  INDEX,
  MIDDLE,
  RING,
  PINKY,
  OKTH,
  MIDTH,
};

Gesture gestureBuf[GESTURE_AVG_N];
int gestureIdx = 0;

// =========================
// Helpers
// =========================
int updateAvg(int raw, int *buf, int &idx, long &sum) {
  sum -= buf[idx];
  buf[idx] = raw;
  sum += raw;
  idx = (idx + 1) % AVG_N;
  return (int)(sum / AVG_N);
}

const char* gestureName(Gesture g) {
  switch (g) {
    case REST: return "REST";
    case FIST: return "FIST";
    case PINCH: return "PINCH";
    case PEACE: return "PEACE";
    case POINT: return "POINT";
    case THUMB: return "THUMB";
    case INDEX: return "INDEX";
    case MIDDLE: return "MIDDLE";
    case RING: return "RING";
    case PINKY: return "PINKY";
    case OKTH: return "OKTH";
    case MIDTH: return "MIDTH";
  }
  return "UNKNOWN";
}

// =========================
// Classifier
// =========================
Gesture classifyGesture(int F, int F_std, int P, int P_std, int E, int E_std) {

  if (F < 18 && P < 220 && E < 3) return REST;

  if (F > 120) return RING;

  if (P > 500 && E > 25) return PINKY;

  if (P > 350 && E < 25 && F < 105) return INDEX;

  if (P < 230 && E < 10) return POINT;

  if (F < 32 && E < 3 && P > 255 && P < 320) return PINCH;

  if (F > 18 && F < 42 && E > 12 && P > 160 && P < 285) return FIST;

  if (F > 18 && F < 40 && E > 6 && E < 25 && P > 185 && P < 255) return OKTH;

  if (F > 35 && F < 58 && E < 12 && P > 280 && P < 365) return PEACE;

  if (F < 30 && E < 2 && P > 240 && P < 280) return MIDTH;

  if (F > 30 && F < 55 && E < 5 && P > 280 && P < 340) return MIDDLE;

  if (F > 25 && F < 60 && E > 5 && E < 20 && P > 210 && P < 270) return THUMB;

  return REST;
}

// =========================
// Gesture averaging (majority vote)
// =========================
Gesture getAveragedGesture(Gesture newGesture) {

  // Insert into circular buffer
  gestureBuf[gestureIdx] = newGesture;
  gestureIdx = (gestureIdx + 1) % GESTURE_AVG_N;

  // Count occurrences
  int counts[12] = {0};

  for (int i = 0; i < GESTURE_AVG_N; i++) {
    counts[gestureBuf[i]]++;
  }

  // Find most frequent
  int maxCount = 0;
  Gesture bestGesture = REST;

  for (int i = 0; i < 12; i++) {
    if (counts[i] > maxCount) {
      maxCount = counts[i];
      bestGesture = (Gesture)i;
    }
  }

  return bestGesture;
}

// =========================
// Setup
// =========================
void setup() {
  Serial.begin(115200);
  mySerial.begin(115200, SERIAL_8N1, -1, 17);

  // Initialize gesture buffer to REST
  for (int i = 0; i < GESTURE_AVG_N; i++) {
    gestureBuf[i] = REST;
  }
}

// =========================
// Loop (REAL-TIME)
// =========================
void loop() {

  // --- Raw reads ---
  int rawF = analogRead(FIST_PIN);
  int rawP = analogRead(PINCH_PIN);
  int rawE = analogRead(EXTENSION_PIN);

  // --- Optional EMG rectification ---
  // rawF = abs(rawF);
  // rawP = abs(rawP);
  // rawE = abs(rawE);

  // --- Moving average ---
  int avgF = updateAvg(rawF, bufF, idxF, sumF);
  int avgP = updateAvg(rawP, bufP, idxP, sumP);
  int avgE = updateAvg(rawE, bufE, idxE, sumE);

  // --- Real-time classification ---
  Gesture candidate = classifyGesture(avgF, 0, avgP, 0, avgE, 0);

  // --- Averaged output gesture ---
  Gesture outputGesture = getAveragedGesture(candidate);

  // --- Send to Pi ---
  mySerial.println(gestureName(outputGesture));

  // --- Debug ---
  Serial.print("F=");
  Serial.print(avgF);
  Serial.print(", P=");
  Serial.print(avgP);
  Serial.print(", E=");
  Serial.print(avgE);
  Serial.print(" -> ");
  Serial.println(gestureName(outputGesture));

  delay(delayTime);
}
